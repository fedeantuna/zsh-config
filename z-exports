HISTFILE=$HOME/.histfile
HISTSIZE=1000000
SAVEHIST=1000000

if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]
then
	PATH="$HOME/.local/bin":$HOME/bin:$PATH
fi

export PATH
locate --basename '\rg' &>/dev/null && export FZF_DEFAULT_COMMAND='rg --files --no-ignore --hidden --follow --glob "!.git/*"'
